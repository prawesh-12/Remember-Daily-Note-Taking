# Backend and Vite both read from here.

# --- Backend ---
NODE_ENV=development
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/remember-daily
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:5173

# Google OAuth (backend verification)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upstash (optional; omit or set RATE_LIMIT_ENABLED=false to skip)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_FAIL_OPEN=true

# --- Frontend (Vite: only VITE_* are exposed to the browser) ---
VITE_GOOGLE_CLIENT_ID=
